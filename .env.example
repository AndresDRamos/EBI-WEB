# =============================================================================
# EBI-Web — Variables de entorno (PLANTILLA)
# Copia este archivo a `.env` y rellena los valores. NUNCA versiones `.env`.
# =============================================================================

# --- Entorno ---
NODE_ENV=development
APP_PORT=3001

# --- Autenticación Entra ID (MSAL) — login del portal ---
# App registration ya existente en Entra.
NEXT_PUBLIC_AZURE_AD_CLIENT_ID=
NEXT_PUBLIC_AZURE_AD_TENANT_ID=
NEXT_PUBLIC_AZURE_AD_REDIRECT_URI=http://localhost:3001
NEXT_PUBLIC_AZURE_AD_POST_LOGOUT_URI=http://localhost:3001

# --- Power BI ---
# Scope para org-embed (user owns data) en desarrollo:
NEXT_PUBLIC_POWERBI_SCOPE=https://analysis.windows.net/powerbi/api/.default
# Producción (app owns data) — service principal (NO en repo; usar Key Vault):
# PBI_SP_CLIENT_ID=
# PBI_SP_CLIENT_SECRET=
# PBI_SP_TENANT_ID=
# PBI_WORKSPACE_ID=

# --- Base de datos EBI (Azure SQL) — runtime de la app (usuario ebi_app) ---
DB_SERVER=servereps.database.windows.net
DB_DATABASE=EBI_dev
DB_USER=ebi_app
DB_PASSWORD=
DB_ENCRYPT=true

# --- Credenciales para herramientas de agente / migraciones (solo local) ---
# Usuario de SOLO LECTURA que usa el MCP del sub-agente DBA:
EBI_AGENT_RO_PASSWORD=
# Usuario MIGRADOR que usa Flyway (DDL):
EBI_MIGRATOR_PASSWORD=

# --- EPS (origen del ETL, solo lectura) — el acceso real lo da el MCP global ---
# Documentado en el skill eps-fuentes (SQL Server 192.168.4.5). No se ponen
# credenciales de EPS aquí; el MCP sqlserver-eps las gestiona globalmente.
