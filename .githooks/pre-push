#!/bin/sh
# Bloquea pushes directos a main: el único camino es un Pull Request
# (README → Git conventions). Sustituto local de la protección de rama,
# que GitHub no ofrece en repos privados con plan gratuito.
#
# Se activa una vez por clon:   git config core.hooksPath .githooks
# Emergencia real:              ALLOW_MAIN_PUSH=1 git push ...

[ "$ALLOW_MAIN_PUSH" = "1" ] && exit 0

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    echo "✋ Push directo a main bloqueado — abre un Pull Request." >&2
    echo "   (Emergencia: ALLOW_MAIN_PUSH=1 git push ...)" >&2
    exit 1
  fi
done

exit 0
